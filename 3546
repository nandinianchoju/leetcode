class Solution:
    def canPartitionGrid(self, grid):
        m, n = len(grid), len(grid[0])
        
        total = 0
        row_sums = [0] * m
        col_sums = [0] * n
        
        # Compute sums
        for i in range(m):
            for j in range(n):
                val = grid[i][j]
                total += val
                row_sums[i] += val
                col_sums[j] += val
        
        if total % 2 != 0:
            return False
        
        target = total // 2
        
        # Horizontal cut
        curr = 0
        for i in range(m - 1):
            curr += row_sums[i]
            if curr == target:
                return True
        
        # Vertical cut
        curr = 0
        for j in range(n - 1):
            curr += col_sums[j]
            if curr == target:
                return True
        
        return False
